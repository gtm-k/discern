{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gtm-k/discern/schemas/profile.schema.json",
  "title": "Preference Profile",
  "description": "Per-person preferences and value framework. A 'self' profile is the user's own; 'recipient' profiles are built up over time for gifting. The active beneficiary selects which profile loads (see docs/definitions.md gift branches).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "value_framework"],
  "properties": {
    "schema_version": { "type": "string" },
    "kind": { "enum": ["self", "recipient"] },
    "name": { "type": "string", "description": "Required when kind=recipient (e.g. 'Mom')." },
    "relationship": { "type": "string" },
    "occasion_history": {
      "type": "array",
      "description": "Past gifts to this recipient — used to avoid repeats.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["occasion", "gift"],
        "properties": {
          "occasion": { "type": "string" },
          "date": { "type": "string" },
          "gift": { "type": "string" }
        }
      }
    },
    "value_framework": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principles"],
      "properties": {
        "principles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Free-form value statements, e.g. 'value != price', 'handmade/local = value', 'reject markup without substance'."
        },
        "prefers_handmade_local": { "type": "boolean" },
        "markup_tolerance": { "enum": ["low", "moderate", "high"] }
      }
    },
    "hard_filters": {
      "type": "array",
      "description": "Disqualifying rules. applies_to_gifts controls whether the filter transfers when this person is the SELF but buying a gift (most self-filters do NOT auto-apply to recipients).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "rule"],
        "properties": {
          "dimension": { "type": "string", "description": "e.g. 'materials', 'origin', 'repairability'." },
          "rule": { "type": "string", "description": "e.g. 'natural/non-synthetic only (linen, cotton, wool)'." },
          "applies_to_gifts": { "type": "boolean", "default": false }
        }
      }
    },
    "preferences": {
      "type": "array",
      "description": "Soft preferences (weighted, not disqualifying).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "preference"],
        "properties": {
          "dimension": { "type": "string" },
          "preference": { "type": "string" },
          "weight": { "enum": ["low", "medium", "high"] }
        }
      }
    },
    "category_budgets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "currency", "typical_max"],
        "properties": {
          "category": { "type": "string" },
          "currency": { "type": "string" },
          "typical_max": { "type": "number" },
          "target": { "type": "number" }
        }
      }
    },
    "brand_trust": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trusted": { "type": "array", "items": { "type": "string" } },
        "distrusted": { "type": "array", "items": { "type": "string" } }
      }
    },
    "sizes": {
      "type": "object",
      "description": "Free-form sizing notes (clothing/shoes), mainly for recipient profiles.",
      "additionalProperties": { "type": "string" }
    },
    "notes": { "type": "string" }
  },
  "if": { "properties": { "kind": { "const": "recipient" } }, "required": ["kind"] },
  "then": { "required": ["name"] }
}

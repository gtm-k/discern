{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","additionalProperties":false,
  "required":["id","need","axes","dealbreaker_rules","counts","radar_default","items"],
  "properties":{
    "id":{"type":"string"},
    "need":{"type":"string"},
    "axes":{"const":["fundamentals","consensus","evidence","clean"]},
    "dealbreaker_rules":{"type":"array","items":{"type":"string"}},
    "counts":{"type":"object","additionalProperties":false,
      "required":["considered","eligible","removed"],
      "properties":{
        "considered":{"type":"integer","minimum":0},
        "eligible":{"type":"integer","minimum":0},
        "removed":{"type":"integer","minimum":0}}},
    "radar_default":{"type":"object","additionalProperties":false,
      "required":["series"],
      "properties":{"series":{"type":"array","items":{"type":"string"},"maxItems":2}}},
    "items":{"type":"array",
      "items":{"type":"object","additionalProperties":false,
        "required":["product","maker","status","disqualified_reason","dealbreaker_rule","durable_unresolved","scores"],
        "properties":{
          "product":{"type":"string"},
          "maker":{"type":"string"},
          "status":{"type":"string","enum":["pick","runner_up","eligible","not_shortlisted","disqualified"]},
          "disqualified_reason":{"type":["string","null"]},
          "dealbreaker_rule":{"type":["string","null"]},
          "durable_unresolved":{"type":"boolean"},
          "scores":{"type":"object","additionalProperties":false,
            "required":["fundamentals","consensus_raw","consensus_norm","evidence","clean"],
            "properties":{
              "fundamentals":{"type":["number","null"],"minimum":0,"maximum":1},
              "consensus_raw":{"type":"integer","minimum":0},
              "consensus_norm":{"type":["number","null"],"minimum":0,"maximum":1},
              "evidence":{"type":"number","minimum":0,"maximum":1},
              "clean":{"type":["number","null"],"minimum":0,"maximum":1}}}}}}}}

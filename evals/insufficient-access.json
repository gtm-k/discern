{
  "_doc": "Phase 5 INSUFFICIENT_ACCESS path — when no usable tier is available, OR budgets are exhausted before any credible evidence is gathered, the run returns outcome=INSUFFICIENT_EVIDENCE with reason_code=INSUFFICIENT_ACCESS. It NEVER fabricates a pick to fill a data gap. Drives tools/orchestration.mjs::orchestrate.",
  "cases": [
    {
      "name": "no usable tier (even baseline unavailable) -> INSUFFICIENT_ACCESS",
      "capabilities": { "baseline": false, "subagents": false, "browser": false, "api": false },
      "plan": { "work": [] },
      "expect": {
        "access": "insufficient",
        "outcome": "INSUFFICIENT_EVIDENCE",
        "reason_code": "INSUFFICIENT_ACCESS",
        "evidence_gathered": false
      }
    },
    {
      "name": "budgets exhausted before any evidence -> INSUFFICIENT_ACCESS",
      "capabilities": { "subagents": true, "browser": true, "api": true },
      "budgets": { "max_fetches": 0 },
      "plan": {
        "queries": ["best car seat"],
        "work": [
          { "type": "fetch", "domain": "a.example", "yields_evidence": true },
          { "type": "fetch", "domain": "b.example", "yields_evidence": true }
        ]
      },
      "expect": {
        "access": "insufficient",
        "outcome": "INSUFFICIENT_EVIDENCE",
        "reason_code": "INSUFFICIENT_ACCESS",
        "evidence_gathered": false,
        "budgets_hit_includes": "max_fetches"
      }
    },
    {
      "name": "api-only work with the api tier disabled -> INSUFFICIENT_ACCESS (tier-unavailability, not budget)",
      "capabilities": { "subagents": false, "browser": false, "api": false },
      "plan": {
        "queries": ["authoritative live price"],
        "work": [
          { "type": "api", "yields_evidence": true },
          { "type": "api", "yields_evidence": true }
        ]
      },
      "expect": {
        "access": "insufficient",
        "outcome": "INSUFFICIENT_EVIDENCE",
        "reason_code": "INSUFFICIENT_ACCESS",
        "evidence_gathered": false
      }
    },
    {
      "name": "all work items malformed/unknown-type -> nothing reachable -> INSUFFICIENT_ACCESS",
      "capabilities": { "subagents": false, "browser": false, "api": false },
      "plan": {
        "work": [
          { "type": "fetchh", "domain": "typo.example", "yields_evidence": true },
          { "nonsense": true }
        ]
      },
      "expect": {
        "access": "insufficient",
        "outcome": "INSUFFICIENT_EVIDENCE",
        "reason_code": "INSUFFICIENT_ACCESS",
        "evidence_gathered": false
      }
    }
  ]
}
